# History Shorts pipeline configuration (§7).
#
# Secrets (API keys, OAuth refresh tokens, service-account JSON) live in
# Supabase Vault, NOT here. This file holds only non-secret config flags plus
# the two bootstrap values needed to reach Supabase in the first place.

# ---- Supabase (source of truth + storage) ----
SUPABASE_URL=
# Service-role key. This is the ONLY secret in env; it exists solely to open
# the Vault. Everything else is read from Vault server-side.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Server ----
PORT=3000
# Comma-separated cron controller auth token check is skipped in dev.
NODE_ENV=development

# ---- Config flags (§7) ----
# When false (default) YouTube Shorts upload as private + scheduled. This is the
# human safety net for hallucinated facts. Flip to true only once trusted.
YT_AUTO_PUBLIC=false

# When false, skip YouTube upload entirely (Drive/TikTok-only phase). The
# youtube_shorts destination row stays 'pending' for a later backfill.
YT_ENABLED=true

# GPU provider config. Provider is interfaced; 'mock' runs the pipeline with no
# real GPU (for dry runs / CI). Real values: 'runpod' | 'vastai'.
GPU_PROVIDER=mock
GPU_INSTANCE_TYPE=NVIDIA_RTX_4090
# Hard kill ceiling in minutes. Reaper and controller enforce this.
GPU_MAX_RUNTIME_MIN=30

# TTS provider (interfaced; do not hardcode). 'xtts' self-hosted default,
# 'mock' for dry runs, or a paid provider slug behind the same interface.
TTS_PROVIDER=mock

# Pitch-preserving narration speed-up applied at compose time (ffmpeg atempo).
VOICE_SPEED=1.15

# Drive write scope is auto-detected on boot. This may be forced off to always
# use the Supabase Storage fallback bucket.
DRIVE_WRITE_ENABLED=auto

# ID of the "TikTok Queue" folder in the owner's Drive, shared (Editor) with
# the service account. Required for Drive writes: service accounts have no
# storage quota, so uploads must land in a human-owned folder. Empty => the
# Storage fallback bucket is used.
DRIVE_QUEUE_FOLDER_ID=

# Comma-separated list of series slugs the cron should run. Empty = none.
SERIES_ENABLED=

# Comma-separated HH:MM times (server-local; UTC on Render) to run EVERY
# enabled series each day. Empty = each series' own post_time, once daily.
POST_TIMES=

# Default length profile. 'short' (30-45s) ships; 'mono' (60-90s) exists but is
# unused in the growth phase.
TARGET_LENGTH_PROFILE=short

# ---- Notifications (§4.7) ----
# Optional Slack incoming webhook for run summaries. If unset, summaries are logged.
SLACK_WEBHOOK_URL=

# ---- Claude ----
# API key is read from Vault (key: 'anthropic_api_key'). For local dev you may
# set it here and the vault lookup will fall back to it.
ANTHROPIC_API_KEY=
